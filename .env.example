# ========== 本地模型配置 (qwen3-32B-FP16) ==========
# 需先启动 vLLM: ./scripts/start_vllm.sh
LOCAL_MODEL_BASE_URL=http://localhost:8000/v1
LOCAL_MODEL=qwen3-32B-FP16
LOCAL_MODEL_PATH=/mnt/data/zhangchen/models/qwen3-32B-FP16
LOCAL_MODEL_API_KEY=EMPTY

# Optional safety switch
ENABLE_KEYWORD_RISK_OVERRIDE=true

# Runtime tuning
STAGE_MAX_TOKENS=800
RISK_MAX_TOKENS=600
MODEL_TIMEOUT_SECONDS=120
